{
  "name": "thymx",
  "version": "0.0.1",
  "scripts": {
    "build": "npm run format && cross-env NODE_ENV=production npx webpack --mode=production",
    "build:dev": "npm run format && cross-env NODE_ENV=development npx webpack --mode=development",
    "clean": "npm prune && npm cache verify",
    "clear": "npm run clean",
    "ncu": "npx ncu",
    "format": "npx prettier **/*.{cjs,css,html,js,json,mjs,scss,svg,tjs,ts,xml,yaml,yml} --write",
    "lint": "npx eslint"
  },
  "type": "module",
  "devDependencies": {
    "@alpinejs/csp": "^3.15.8",
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/css": "^1.0.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^1.2.0",
    "@eslint/markdown": "^7.5.1",
    "@prettier/plugin-xml": "^3.4.2",
    "@tailwindcss/language-server": "^0.14.29",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.8",
    "babel-loader": "^10.1.1",
    "browserslist": "^4.28.1",
    "core-js": "^3.49.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "daisyui": "^5.5.19",
    "eslint": "^10.1.0",
    "flatpickr": "^4.6.13",
    "fork-ts-checker-webpack-plugin": "^9.1.0",
    "globals": "^17.4.0",
    "htmx.org": "^2.0.8",
    "mini-css-extract-plugin": "^2.10.1",
    "npm-check-updates": "^19.6.5",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-attributes": "^1.0.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "regenerator-runtime": "^0.14.1",
    "tailwindcss": "^4.2.2",
    "terser-webpack-plugin": "^5.4.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "webpack": "^5.105.4",
    "webpack-assets-manifest": "^6.5.1",
    "webpack-cli": "^7.0.2"
  },
  "prettier": {
    "attributeSort": "ASC",
    "bracketSameLine": true,
    "plugins": [
      "@prettier/plugin-xml",
      "prettier-plugin-organize-attributes",
      "prettier-plugin-tailwindcss"
    ],
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "singleAttributePerLine": true
  },
  "browserslist": [
    ">0.3%, defaults, fully supports es6-module"
  ]
}
